<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Light -->
    <Color x:Key="BgLight">#F8FAFC</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="Surface2Light">#F1F5F9</Color>
    <Color x:Key="BorderLight">#E2E8F0</Color>
    <Color x:Key="TextLight">#0F172A</Color>
    <Color x:Key="MutedLight">#64748B</Color>

    <!-- Dark -->
    <Color x:Key="BgDark">#0B1220</Color>
    <Color x:Key="SurfaceDark">#111B2E</Color>
    <Color x:Key="Surface2Dark">#0F1A2F</Color>
    <Color x:Key="BorderDark">#223047</Color>
    <Color x:Key="TextDark">#E5E7EB</Color>
    <Color x:Key="MutedDark">#94A3B8</Color>

    <!-- Brand -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>

    <!-- Status -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#DC2626</Color>

</ResourceDictionary>
