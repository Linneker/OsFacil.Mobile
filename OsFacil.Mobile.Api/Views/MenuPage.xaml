<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OsFacil.Mobile.Api.ViewModels"
             x:Class="OsFacil.Mobile.Api.Views.MenuPage"
             x:DataType="vm:MenuViewModel"
             Title="Menu"
             >
    <ScrollView Padding="10">
    <VerticalStackLayout Padding="16" Spacing="12">

        <Label Text="OsFácil" FontSize="20" FontAttributes="Bold" />
        <Label Text="Ordem de serviço facil e pratico." FontSize="13" Opacity="0.7" />

            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None" x:Name="MenuList" >
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:MenuItemVm">
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#223047}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111B2E}"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto">
                                <Button Grid.Column="0"
                                    Text="{Binding Title}"
                                    FontSize="16"
                                    TextColor="Gray"
                                    VerticalOptions="Center"
                                    BackgroundColor="Transparent"
                                    Clicked="SendPageMenu"
                                    Command="{Binding BindingContext.SelectCommand, Source={x:Reference MenuList}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
    </ScrollView>
</ContentPage>
