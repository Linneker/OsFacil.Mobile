<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OsFacil.Mobile.Api.Views.Clients.ClientPage"
    x:Name="ClientPageDelete"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:OsFacil.Mobile.Api.ViewModels.Clients"
    xmlns:m="clr-namespace:OsFacil.Mobile.Api.Models.Clients"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:ClientViewModel"
    Title="Clientes"
    BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="16,14"
              ColumnDefinitions="*,Auto"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#111B2E}">


            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                <Button Text="Cadastrar"
                        Command="{Binding AddClientCommand}"
                        HeightRequest="40"
                        FontSize="13"
                        CornerRadius="12"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#0F172A}"
                        TextColor="White" />

                <Button Text="Recarregar"
                        Command="{Binding ReloadCommand}"
                        HeightRequest="40"
                        FontSize="13"
                        CornerRadius="12"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#0B1220}"
                        TextColor="{AppThemeBinding Light=#0F172A, Dark=#E5E7EB}"
                        BorderWidth="1"
                        BorderColor="{AppThemeBinding Light=#CBD5E1, Dark=#223047}" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Busca -->
        <Grid Grid.Row="1"
              Padding="16,10"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#111B2E}">
            <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#223047}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#0B1220}"
                    Padding="12,8">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Entry Grid.Column="1"
                           Placeholder="Buscar cliente..."
                           Text="{Binding SearchText}"
                           ReturnType="Search" />
                    <Image Source="search_img.png"
                        HeightRequest="30"
                        WidthRequest="30"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Opacity="0.9" />
                </Grid>
            </Border>
        </Grid>

        <!-- ✅ Refresh (Pull-to-refresh) + Lista -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     Command="{Binding RefreshCommand}">

            <CollectionView x:Name="ClientsList" 
                            Margin="16,12"
                            ItemsSource="{Binding Items}"
                            RemainingItemsThreshold="4"
                            SelectionMode="None">

                <!-- Scroll infinito -->
                <CollectionView.Behaviors>
                    <toolkit:EventToCommandBehavior
                        EventName="RemainingItemsThresholdReached"
                        Command="{Binding LoadMoreCommand}" />
                </CollectionView.Behaviors>

                <CollectionView.ItemTemplate>
                    <!-- Como você pediu: item também é ClientViewModel -->
                    <DataTemplate x:DataType="m:ClientModel">

                        <Border Margin="0,0,0,10"
                                Padding="14,12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#223047}"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#111B2E}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                <!-- Nome + Contato -->
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding Phone}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding Email}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <!-- Excluir menor -->
                                <ImageButton Grid.Column="1"
                                        Source="remove_img.png"
                                        HeightRequest="25"
                                        WidthRequest="40"
                                        CornerRadius="12"
                                        Padding="0"
                                        Clicked="OnDeleteClicked"
                                        Command="{Binding BindingContext.DeleteCommand, Source={x:Reference ClientsList}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
