<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:OsFacil.Mobile.Api"
             xmlns:conv="clr-namespace:OsFacil.Mobile.Api.Converters"
             x:Class="OsFacil.Mobile.Api.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToExpiredColorConverter x:Key="BoolToExpiredColorConverter" />
            <conv:BoolToExpiredTextConverter x:Key="BoolToExpiredTextConverter" />
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>

</Application>
